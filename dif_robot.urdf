<?xml version="1.0"?>
<robot name="dif_robot">
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="green">
        <color rgba="0.6 0.39 0.45 1"/>
    </material>

    <material name="white">
        <color rgba="1 1 1 1"/>
    </material>

    <link name="base_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10.0"/> 
            <inertia ixx="0.1667" ixy="0.0" ixz="0.0" iyy="0.2333" iyz="0.0" izz="0.3333"/> 
        </inertial>
        <visual>
            <geometry>
                <box size="0.6 0.4 0.2"/>    
            </geometry>    
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.6 0.4 0.2"/>    
            </geometry>    
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <material name="black"/>
        </collision>
    </link>    

    <link name="lidar_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/> 
            <inertia ixx="0.000275" ixy="0.0" ixz="0.0" iyy="0.000275" iyz="0.0" izz="0.0005"/> 
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="white"/>
        </visual>
    </link>

    <link name="left_wheel">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5"/>
            <inertia ixx="0.01375" ixy="0.0" ixz="0.0" iyy="0.01375" iyz="0.0" izz="0.025"/> 
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
        </collision>
    </link>

    <link name="right_wheel">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="5"/> 
            <inertia ixx="0.01375" ixy="0.0" ixz="0.0" iyy="0.01375" iyz="0.0" izz="0.025"/>
        </inertial>
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
            <material name="white"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
        </collision>
    </link>
    
    <!-- Replaced caster wheel with the caster from rikkert -->

    <link name="caster_wheel">
        <visual>
            <origin rpy="1.5708 0 0" xyz="0 0 0"/> <!-- Oriented correctly to represent a wheel -->
            <geometry>
                <cylinder radius="0.06" length="0.04"/> <!-- Larger wheel for better ground contact -->
            </geometry>
            <material name="black">
                <color rgba="0.0 0.0 0.0 1.0"/>
            </material>
        </visual>
        <collision>
            <origin rpy="1.5708 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.06" length="0.04"/> <!-- Collision geometry matches visual -->
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.25"/> <!-- Mass slightly increased for balance -->
            <inertia ixx="0.0025" ixy="0.0" ixz="0.0" iyy="0.0025" iyz="0.0" izz="0.0025"/>
        </inertial>
    </link>

    <link name="caster_body">
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.08"/> <!-- Caster body with larger, more balanced dimensions -->
            </geometry>
            <material name="gray">
                <color rgba="0.5 0.5 0.5 1.0"/>
            </material>
        </visual>
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0"/>
            <geometry>
                <cylinder radius="0.05" length="0.08"/> <!-- Collision matches visual to prevent inconsistency -->
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.4"/> <!-- Increased mass to provide stability -->
            <inertia ixx="0.003" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.003"/>
        </inertial>
    </link>

    <joint name="caster_swivel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="caster_body"/>
        <origin rpy="0 0 0" xyz="0.2 0 -0.03"/> <!-- Position of caster relative to base -->
        <axis xyz="0 0 1"/> <!-- Allows swiveling around the vertical axis (z-axis) -->
        <dynamics damping="0.5" friction="0.5"/> <!-- Increased damping and friction to stabilize the caster -->
    </joint>

    <joint name="caster_rolling_joint" type="revolute">
        <parent link="caster_body"/>
        <child link="caster_wheel"/>
        <origin rpy="0 0 0" xyz="0 0 -0.06"/> <!-- Attaches wheel to the caster body -->
        <axis xyz="0 1 0"/> <!-- Rolling axis is horizontal, allowing the wheel to rotate around the x-axis -->
        <dynamics damping="0.5" friction="0.5"/> <!-- Increased damping and friction to ensure smoother rolling motion -->
        <limit lower="-100000000" upper="100000000" effort="50" velocity="10"/>
    </joint>

    <joint name="base_lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.225"/>
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="-0.15 0.225 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-100000000" upper="100000000" effort="50" velocity="500"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="-0.15 -0.225 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-100000000" upper="100000000" effort="50" velocity="500"/>
        <dynamics damping="0.5" friction="0.2"/>
    </joint>
</robot>
